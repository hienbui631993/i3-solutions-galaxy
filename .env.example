# Copy this file to ".env" and fill in your key, then restart `npm run dev`.
# Used server-side by the /api/ask proxy in vite.config.js — never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------------------
# 2FA auth (serverless functions in /api). Set these in the Vercel project's
# Environment Variables — they are read server-side and never reach the browser.
# ---------------------------------------------------------------------------
# Shared sign-in password (first factor).
AUTH_APP_PASSWORD=choose-a-strong-password
# Long random strings used to sign session + challenge tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=replace-with-32-byte-random-hex
AUTH_CHALLENGE_SECRET=replace-with-another-32-byte-random-hex
# Resend API key (https://resend.com) for emailing the one-time code.
RESEND_API_KEY=re_your_key_here
# Verified sender. The shared onboarding@resend.dev works only to your own
# Resend account email until you verify a domain.
AUTH_EMAIL_FROM=i3 Solution Galaxy <noreply@yourdomain.com>

# Local dev only: skip the whole auth gate when running `vite dev` without the
# serverless backend. NEVER set this in production.
# VITE_DISABLE_AUTH=true
