# Copy this file to ".env" and fill in your key, then restart `npm run dev`.
# Used server-side by the /api/ask proxy in vite.config.js — never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---------------------------------------------------------------------------
# App auth (serverless functions in /api): allowlisted email + shared password,
# 1-hour session. Set these in the Vercel project's Environment Variables —
# they are read server-side and never reach the browser.
# ---------------------------------------------------------------------------
# The sign-in password is today's date as YYYYMMDD (rotates daily) — no env
# var needed for it. Timezone for "today" defaults to UTC; override if needed:
# AUTH_DATE_TZ=America/Toronto
# Optional fixed override password (admin backdoor); leave unset to require the date.
# AUTH_APP_PASSWORD=
# Long random string used to sign the session token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SESSION_SECRET=replace-with-32-byte-random-hex

# Local dev only: skip the whole auth gate when running `vite dev` without the
# serverless backend. NEVER set this in production.
# VITE_DISABLE_AUTH=true
